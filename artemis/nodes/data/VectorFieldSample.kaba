use artemis.*

class VectorFieldSample extends Node
	var in_field = InPort[VectorField](self, "in")
	var out_vector = OutPort[vec3](self, "out")
	var index = Setting[i32](self, "index", 0)
	
	func __init__()
		super.__init__("VectorFieldSample")
	
	func override on_process()
		for f in in_field.value()
			out_vector.set(f.value(index()))
		
	
