use artemis.*

class ScaleVector extends Node
	var in_vector = InPort[vec3](self, "in")
	var out_vector = OutPort[vec3](self, "out")
	var factor = Setting[f64](self, "factor", 1)
	
	func __init__()
		super.__init__("ScaleVector")
	
	func override on_process()
		for v in in_vector.value()
			out_vector.set(v * f32(factor()))
		
	
