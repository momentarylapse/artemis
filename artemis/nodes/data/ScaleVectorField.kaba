use artemis.*

class ScaleVectorField extends Node
	var in_field = InPort[VectorField](self, "in")
	var out_field = OutPort[VectorField](self, "out")
	var factor = Setting[f64](self, "factor", 1.0)
	
	func __init__()
		super.__init__("ScaleVectorField")
	
	func override on_process()
		for f in in_field.value()
			out_field.set(f * factor())
