use artemis.*

class ScalarFieldSample extends Node
	var in_field = InPort[ScalarField](self, "in")
	var out_vector = OutPort[f64](self, "out")
	var index = Setting[i32](self, "index", 0)
	
	func __init__()
		super.__init__("FloatFieldSample")
	
	func override on_process()
		for f in in_field.value()
			out_vector.set(f.value(index()))
		
	
