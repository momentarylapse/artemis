use artemis.*

class ScaleNumber extends Node
	var in_float: InPort[f64]
	var out_float: OutPort[f64]
	var factor: Setting[f64]
	
	func __init__()
		super.__init__("ScaleNumber")
		in_float.__init__(self, "in")
		out_float.__init__(self, "out")
		factor.__init__(self, "factor", 1)
	
	func override on_process()
		for v in in_float.value()
			out_float.set(v * factor())
		
	
