use artemis.*

class ScaleNumber extends Node
	var in_float = InPort[f64](self, "in")
	var out_float = OutPort[f64](self, "out")
	var factor = Setting[f64](self, "factor", 1)
	
	func __init__()
		super.__init__("ScaleNumber")
	
	func override on_process()
		for v in in_float.value()
			out_float.set(v * factor())
		
	
