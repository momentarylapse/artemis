use artemis.*

class GenericPrint extends Node
	var in_x: InPortBase
	
	func __init__()
		super.__init__("GenericPrint")
		in_x.__init2__(self, "x", nil)
	
	func override on_process()
		for i=>v in in_x.generic_values()
			print(v.type)
			match v.type
				i32 =>    print(v.p as i32&)
				f64 =>    print(v.p as f64&)
				string => print(v.p as string&)
				vec3 =>   print(v.p as vec3&)
			#	f64[] =>  print(v.p as f64[]&)
			#	vec3[] => print(v.p as vec3[]&)
				else =>   print("???")

