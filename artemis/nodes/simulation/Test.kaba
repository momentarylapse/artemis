use artemis.*

class Test extends Node	
	var in_x = InPort[ScalarField](self, "x", PortFlags.MUTABLE)
	#var out_y = OutPort[ScalarField](self, "y")


	func __init__()
		super.__init__("Test")
		flags = NodeFlags.TIME_DEPENDENT
	
	func override on_process()
		let t = current_session().t
		for mut f in in_x.value()
			for i in 0:f.grid.nx
				for j in 0:f.grid.ny
					for k in 0:f.grid.nz
						f._set(i, j, k, sin(k*0.3 + t))
			in_x.mutated()
			#out_y.set(laplace(f))
		
