use artemis.*
use os
use image

class ImageFile extends Node
	var out_image = OutPort[image.Image](self, "out", PortFlags.MUTABLE)
	var file = Setting[os.Path](self, "file", "")

	func __init__()
		super.__init__("ImageFile")
		flags = NodeFlags.RESOURCE

	func override on_process()
		let i = image.Image.load(file())
		if weak(i) # ...
			out_image.set(i)
		else
			error("failed to load {{file()}}")

