use kaba
use os.Path
use .data.*
use .grid.*
use .fields.*
use .graph.*
use .session.*
use .render.*

let EXPORT_IMPORTS = true


func extern iso_surface(s: ScalarField, t0: f32) -> Mesh


func main(args: string[])
	var s = create_session()
	if len(args) >= 1
		start_session_load_file(s, args[0])
	else
		start_session_empty(s)
	app_run()
