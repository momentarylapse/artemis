use .graph.*

enum PlotMode
	FUNCTION
	POINTS


struct PlotData
	source: PlotSource&
	mode: PlotMode


class PlotSource extends Node
	var out_plot = OutPort[PlotData](&self, "plot")
	var line_width = Setting[f64](&self, "line-width", 2.0)
	var color = Setting[Color](&self, "color", Color.RED)

	func override mut __init__(name: string)
		super.__init__(name)
	func virtual plot_function(x: f32[]) -> f32[]
		return []
	func virtual plot_points() -> vec2[]
		return []

